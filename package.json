{
  "name": "coolgroove",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit && npm --prefix backend run typecheck",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate:types": "npx swagger2openapi -p -o openapi_3.json swagger_full.json && npx openapi-typescript ./openapi_3.json -o ./src/types/dolibarr.actions.d.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "test:render": "playwright test tests/render --project=chromium --project=\"Mobile Chrome\"",
    "test:e2e:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/e2e-local.ps1",
    "playwright:codegen": "playwright codegen",
    "scrape": "npx tsx scripts/web-scraper.ts",
    "test:app": "npx tsx scripts/test-own-app.ts",
    "browser": "npx tsx scripts/interactive-browser.ts",
    "test:ui-full": "npx tsx scripts/comprehensive-ui-test.ts",
    "test:coolgroove": "npx tsx scripts/coolgroove-complete-test.ts",
    "explore:pages": "npx tsx scripts/explore-all-pages.ts",
    "gc:worktrees": "npx tsx scripts/gc-worktrees.ts",
    "gc:worktrees:dry": "npx tsx scripts/gc-worktrees.ts --dry-run",
    "eval:dunning": "tsx backend/src/eval/dunning.eval.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^10.58.0",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.8",
    "heic2any": "^0.0.4",
    "html2canvas-pro": "^2.0.4",
    "lucide-react": "^0.555.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.1",
    "react-virtualized-auto-sizer": "1.0.24",
    "react-window": "1.8.9",
    "recharts": "^3.5.1",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.10.1",
    "playwright": "^1.58.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  }
}
