# ============================================
# CoolGroove — Frontend (Vite) Configuration
# ============================================
# Copie para .env (na raiz). Todas as variáveis são OPCIONAIS (têm defaults).
# Só variáveis com prefixo VITE_ são expostas ao frontend. NUNCA coloque segredos aqui.
# ============================================

# URL do backend (sobrescreve o default). Em dev, o Vite faz proxy de /api -> backend.
VITE_API_URL=

# URL web do Dolibarr (para deeplinks "abrir no Dolibarr").
VITE_DOLIBARR_URL=https://sistema.coolgroove.com.br

# URL da API usada pelo build mobile (Capacitor), quando aplicável.
VITE_CAPACITOR_API_URL=

# Monitoramento de erros no frontend (Sentry). Vazio = desligado (no-op).
VITE_SENTRY_DSN=

# Versão do app reportada ao Sentry (release).
VITE_APP_VERSION=1.0.0

# Habilita o console de desenvolvimento na UI.
VITE_ENABLE_DEV_CONSOLE=false
