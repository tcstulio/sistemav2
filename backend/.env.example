# ============================================
# CoolGroove ERP - Backend Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development

# WAHA (WhatsApp HTTP API) - Legacy
WAHA_URL=http://localhost:3001

# Dolibarr ERP API
DOLIBARR_API_URL=http://localhost/api/index.php
DOLIBARR_API_KEY=your-dolibarr-api-key-here
DOLIBARR_BYPASS_COOKIE=

# Admin Authentication
# Generate a strong key: openssl rand -hex 32
ADMIN_KEY=your-strong-admin-key-here-min-32-chars

# Encryption key for email credentials at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-encryption-key-here

# Google AI (Gemini)
GOOGLE_GENAI_API_KEY=your-google-api-key-here
AI_MODEL=gemini-2.0-flash

# Local LLM Configuration (optional)
LLM_PROVIDER=local
LOCAL_LLM_URL=http://localhost:8080/v1
LOCAL_LLM_MODEL=your-model-name

# Z.AI (GLM) Configuration
ZAI_API_KEY=your-zai-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4/
ZAI_MODEL=glm-5.1
# Visão (OCR/análise de imagem) via GLM-4.6V — usa a base PaaS padrão (não a 'coding').
# Permite OCR de recibo sem depender do Gemini. Alternativa mais nova: glm-5v-turbo.
ZAI_VISION_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_VISION_MODEL=glm-4.6v

# MiniMax Configuration
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1/
MINIMAX_MODEL=MiniMax-M3
# Geração de mídia (tools do agente). GroupId é opcional (exigido por algumas regiões).
MINIMAX_GROUP_ID=
MINIMAX_TTS_MODEL=speech-2.6-hd
# Voz pt-BR (catálogo MiniMax tem ~73 vozes Portuguese_*). Ex.: Portuguese_ReliableMan,
# Portuguese_Narrator, Portuguese_CalmLeader, Portuguese_SereneWoman.
MINIMAX_VOICE_ID=Portuguese_ConfidentWoman
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3

# ============================================
# MOLTBOT INTEGRATION
# ============================================
# Enable Moltbot Gateway integration
MOLTBOT_ENABLED=false
MOLTBOT_HOST=localhost
MOLTBOT_PORT=18789
MOLTBOT_TOKEN=your-moltbot-gateway-token
MOLTBOT_TIMEOUT=10000

# ============================================
# TULIPA INTEGRATION
# ============================================
# Enable Tulipa Server integration (Brain Hub, Tasks)
TULIPA_ENABLED=false
TULIPA_HOST=localhost
TULIPA_PORT=8081
TULIPA_TIMEOUT=10000

# ============================================
# FEATURE FLAGS
# ============================================
# WhatsApp provider: 'legacy' (whatsapp-web.js) or 'moltbot'
WHATSAPP_PROVIDER=legacy

# Sync events with Tulipa Brain Hub
SYNC_BRAIN_ENABLED=false

# Use Tulipa for task orchestration
TULIPA_TASKS_ENABLED=false

# Memory search via Tulipa (semantic embeddings)
MEMORY_SEARCH_ENABLED=false

# Auto-reply with LLM
AUTO_REPLY_ENABLED=true

# Audio transcription
AUDIO_TRANSCRIPTION_ENABLED=true

# Financial commands via WhatsApp (/pagar, /pix)
FINANCIAL_COMMANDS_ENABLED=false

# CRM context injection in LLM responses
CRM_CONTEXT_INJECTION=true

# Sync Brain people with Dolibarr customers
CRM_SYNC_ENABLED=false

# ============================================
# DEVELOPMENT
# ============================================
# Debug mode (more logs)
DEBUG_MODE=false

# Dry-run mode (don't send real messages)
DRY_RUN_MODE=false

# Chrome executable path (for whatsapp-web.js)
CHROME_BIN=

# ============================================
# BANKING API Configuration
# ============================================
# Banco Inter
INTER_CLIENT_ID=your-inter-client-id
INTER_CLIENT_SECRET=your-inter-client-secret
INTER_CERT_PATH=./certs/inter.crt
INTER_KEY_PATH=./certs/inter.key
INTER_SANDBOX=true
INTER_WEBHOOK_SECRET=your-webhook-secret

# Banco Itau
ITAU_CLIENT_ID=your-itau-client-id
ITAU_CLIENT_SECRET=your-itau-client-secret
ITAU_CERT_PATH=./certs/itau.crt
ITAU_KEY_PATH=./certs/itau.key
ITAU_SANDBOX=true
# Segredo p/ verificar assinatura HMAC-SHA256 dos webhooks Itaú (se vazio, verificação é pulada).
ITAU_WEBHOOK_SECRET=your-itau-webhook-secret
ITAU_CONTA_CORRENTE=
ITAU_AGENCIA=

# ============================================
# EMAIL (Optional)
# ============================================
# IMAP/SMTP Configuration
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
# Validação do certificado TLS do IMAP. Vazio = seguro em produção, relaxado em dev.
# 'true' força validação sempre; 'false' desativa (use só se o servidor tiver cert self-signed).
EMAIL_TLS_REJECT_UNAUTHORIZED=

# ============================================
# Security Notes
# ============================================
# 1. Generate strong random keys for ADMIN_KEY
# 2. Rotate API keys periodically
# 3. Use different keys for dev/staging/production
# 4. Store production secrets in a vault
# 5. Never log or expose these values
