# ============================================
# CoolGroove ERP - Backend Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# Server Configuration
PORT=3004
NODE_ENV=development

# WAHA (WhatsApp HTTP API) - Legacy
WAHA_URL=http://localhost:3001

# Dolibarr ERP API
DOLIBARR_URL=http://localhost/api/index.php
DOLIBARR_API_KEY=your-dolibarr-api-key-here
DOLIBARR_BYPASS_COOKIE=

# Admin Authentication
# Generate a strong key: openssl rand -hex 32
ADMIN_KEY=your-strong-admin-key-here-min-32-chars

# Encryption key for email credentials at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-encryption-key-here

# Segredo opcional p/ os endpoints públicos de webhook (/api/webhook/trigger e /dolibarr/*).
#   • Se vazio em dev/staging: a verificação é pulada (compat legado) e o webhook processa normal.
#   • Se vazio em produção (NODE_ENV=production): o webhook retorna 503 SERVICE_UNAVAILABLE
#     por hardening — DEFINA UM VALOR FORTE para que o webhook funcione em produção.
#     (Quebra intencional do #1543 — quem rodava em prod sem secret porque confiava em IP allowlist
#     precisa setar este valor.)
# Header esperado: x-webhook-signature (também aceito: x-webhook-secret).
WEBHOOK_SECRET=

# Cap de destinatários por chamada de broadcast do scheduler (anti-spam em massa).
# Pode ser sobrescrito em runtime; default 100 (#1543).
# Ordem de precedência (1ª vence): SCHEDULER_BROADCAST_MAX_RECIPIENTS (canônico) →
# SCHEDULER_MAX_BROADCAST (legacy, mantido p/ compat de deploy) → 100.
SCHEDULER_BROADCAST_MAX_RECIPIENTS=100
# SCHEDULER_MAX_BROADCAST=500    # legacy — deixe comentado a menos que tenha deploy antigo

# Google AI (Gemini)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Local LLM Configuration (optional)
LLM_PROVIDER=local
LOCAL_LLM_URL=http://localhost:8080/v1
LOCAL_LLM_MODEL=your-model-name

# ============================================
# LLM FALLBACK CHAIN (cadeia institucional — #784/#789)
# ============================================
# Habilita o wrapper runWithChain que envolve os 16 métodos públicos de aiService.
# default: true em dev/staging, false em produção até #789 validado em staging.
# Para desligar em prod enquanto #789 não está validado, defina false aqui.
# Compat legado: LLM_FALLBACK_ENABLED=false (antigo) também desativa (mapeado internamente).
LLM_RUN_WITH_CHAIN=false

# Cadeia global de fallback (CSV, ordem de preferência).
# Providers válidos: glm, minimax, google, local.
# Providers inválidos são ignorados silenciosamente.
# Quando não definida, cada módulo usa apenas seu provider configurado (sem fallback).
LLM_DEFAULT_CHAIN=glm,minimax

# Overrides por módulo — sobrescrevem LLM_DEFAULT_CHAIN para o módulo específico.
# Deixe comentado para herdar LLM_DEFAULT_CHAIN.
# LLM_CHAT_CHAIN=glm,minimax,google
# LLM_BANKING_CHAIN=glm,google
# LLM_SYSTEM_ANALYSIS_CHAIN=glm
# LLM_PROPOSALS_CHAIN=glm,minimax

# Compat com variável legada (versões anteriores ao #714/#789):
# Definir LLM_FALLBACK_ENABLED=false é equivalente a LLM_RUN_WITH_CHAIN=false.
# Não é necessário definir ambas — prefira LLM_RUN_WITH_CHAIN em novos deploys.
# LLM_FALLBACK_ENABLED=true

# Resiliência de chamada individual (backoff exponencial — #779):
# LLM_PRIMARY_TIMEOUT_MS: timeout por chamada ao provider primário (ms). Default 180s.
# LLM_RETRY_DEADLINE_MS:  prazo total de re-tentativas em erro de infra (ms). Default 60s.
# Reduzir em prod se 180s de espera for inaceitável; aumentar em batch jobs.
LLM_PRIMARY_TIMEOUT_MS=180000
LLM_RETRY_DEADLINE_MS=60000

# Z.AI (GLM) Configuration
ZAI_API_KEY=your-zai-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4/
ZAI_MODEL=glm-5.2
# Transcrição de voz LOCAL (whisper.cpp) — sem nuvem/custo. Setup:
#   1. Baixe whisper-blas-bin-x64.zip de github.com/ggml-org/whisper.cpp/releases
#      e extraia em backend/tools/whisper/ (fica backend/tools/whisper/Release/whisper-cli.exe)
#   2. Baixe o modelo ggml-small.bin de huggingface.co/ggerganov/whisper.cpp
#      para backend/tools/whisper/ggml-small.bin
#   (ffmpeg-static já vem via npm). Com os arquivos presentes, o ASR local assume;
#   sem eles, cai no GLM-ASR-2512 (nuvem, saldo PaaS). Paths customizáveis:
# WHISPER_BIN=
# WHISPER_MODEL=

# Visão (OCR/análise de imagem) via GLM-4.6V — usa a base PaaS padrão (não a 'coding').
# Permite OCR de recibo sem depender do Gemini. Alternativa mais nova: glm-5v-turbo.
ZAI_VISION_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_VISION_MODEL=glm-4.6v

# MiniMax Configuration
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.io/v1/
MINIMAX_MODEL=MiniMax-M3
# Subscription Key da ASSINATURA MiniMax (Token Plan) — chave SEPARADA da API key
# pay-as-you-go; os créditos do plano só valem por ela. Quando presente, os endpoints
# de MÍDIA (TTS/voz/imagem/vídeo) usam esta; o texto (M3) segue na MINIMAX_API_KEY.
# Onde obter: painel platform.minimax.io → página do seu plano/assinatura → Subscription Key.
MINIMAX_MEDIA_KEY=
# Geração de mídia (tools do agente). GroupId é opcional (exigido por algumas regiões).
MINIMAX_GROUP_ID=
MINIMAX_TTS_MODEL=speech-2.6-hd
# Voz pt-BR (catálogo MiniMax tem ~73 vozes Portuguese_*). Ex.: Portuguese_ReliableMan,
# Portuguese_Narrator, Portuguese_CalmLeader, Portuguese_SereneWoman.
MINIMAX_VOICE_ID=Portuguese_ConfidentWoman
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3

# ============================================
# MOLTBOT INTEGRATION
# ============================================
# Enable Moltbot Gateway integration
MOLTBOT_ENABLED=false
MOLTBOT_HOST=localhost
MOLTBOT_PORT=18789
MOLTBOT_TOKEN=your-moltbot-gateway-token
MOLTBOT_TIMEOUT=10000

# ============================================
# TULIPA INTEGRATION
# ============================================
# Enable Tulipa Server integration (Brain Hub, Tasks)
TULIPA_ENABLED=false
TULIPA_HOST=localhost
TULIPA_PORT=8081
TULIPA_TIMEOUT=10000

# ============================================
# FEATURE FLAGS
# ============================================
# WhatsApp provider: 'legacy' (whatsapp-web.js) or 'moltbot'
WHATSAPP_PROVIDER=legacy

# Sync events with Tulipa Brain Hub
SYNC_BRAIN_ENABLED=false

# Use Tulipa for task orchestration
TULIPA_TASKS_ENABLED=false

# Memory search via Tulipa (semantic embeddings)
MEMORY_SEARCH_ENABLED=false

# Auto-reply with LLM
AUTO_REPLY_ENABLED=true

# Audio transcription
AUDIO_TRANSCRIPTION_ENABLED=true

# Financial commands via WhatsApp (/pagar, /pix)
FINANCIAL_COMMANDS_ENABLED=false

# CRM context injection in LLM responses
CRM_CONTEXT_INJECTION=true

# Sync Brain people with Dolibarr customers
CRM_SYNC_ENABLED=false

# ============================================
# DEVELOPMENT
# ============================================
# Debug mode (more logs)
DEBUG_MODE=false

# Dry-run mode (don't send real messages)
DRY_RUN_MODE=false

# Chrome executable path (for whatsapp-web.js)
CHROME_BIN=

# ============================================
# BANKING API Configuration
# ============================================
# Banco Inter
INTER_CLIENT_ID=your-inter-client-id
INTER_CLIENT_SECRET=your-inter-client-secret
INTER_CERT_PATH=./certs/inter.crt
INTER_KEY_PATH=./certs/inter.key
INTER_SANDBOX=true
INTER_WEBHOOK_SECRET=your-webhook-secret

# Banco Itau
ITAU_CLIENT_ID=your-itau-client-id
ITAU_CLIENT_SECRET=your-itau-client-secret
ITAU_CERT_PATH=./certs/itau.crt
ITAU_KEY_PATH=./certs/itau.key
ITAU_SANDBOX=true
# Segredo p/ verificar assinatura HMAC-SHA256 dos webhooks Itaú (se vazio, verificação é pulada).
ITAU_WEBHOOK_SECRET=your-itau-webhook-secret
ITAU_CONTA_CORRENTE=
ITAU_AGENCIA=

# ============================================
# EMAIL (Optional)
# ============================================
# IMAP/SMTP Configuration
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
# Validação do certificado TLS do IMAP. Vazio = seguro em produção, relaxado em dev.
# 'true' força validação sempre; 'false' desativa (use só se o servidor tiver cert self-signed).
EMAIL_TLS_REJECT_UNAUTHORIZED=

# ============================================
# Security Notes
# ============================================
# 1. Generate strong random keys for ADMIN_KEY
# 2. Rotate API keys periodically
# 3. Use different keys for dev/staging/production
# 4. Store production secrets in a vault
# 5. Never log or expose these values

# ===== Preview sandbox (issue #1169) =====
# Quando setados, o backend de PREVIEW do TaskRunner aponta o Dolibarr para o sandbox
# descartável (docker-compose.e2e.yml) em vez da produção. Sem eles, o preview mantém
# o comportamento antigo (leitura da prod; escritas manuais NÃO isoladas — evitar).
# Suba o sandbox com: docker compose -f docker-compose.e2e.yml up -d --build
# A chave é o token do admin do sandbox (login admin/e2eadmin → GET /api/index.php/login).
# PREVIEW_DOLIBARR_URL=http://localhost:8088/api/index.php
# PREVIEW_DOLIBARR_KEY=token-do-admin-do-sandbox
