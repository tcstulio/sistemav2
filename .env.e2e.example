# Config do E2E local (Modo B). Copie para .env.e2e (NÃO versionado) e preencha.
# .env.e2e pode conter chave de um Dolibarr LOCAL — nunca commitar.

# Dolibarr local (default: o docker-compose.e2e.yml sobe na 8088)
DOLIBARR_URL=http://localhost:8088/api/index.php

# API key de um usuário admin do Dolibarr local (gere em: Usuários > admin > API key)
DOLIBARR_API_KEY=
